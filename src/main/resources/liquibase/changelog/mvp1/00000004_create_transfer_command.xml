<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="00000004-1" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="transfer_commands"/>
            </not>
        </preConditions>

        <createTable tableName="transfer_commands">
            <column name="id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="${dateTimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="${dateTimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="bigint"/>

            <column name="transfer_id" type="${uuidType}"/>
            <column name="command_type" type="varchar(255)"/>
            <column name="idempotency_key" type="varchar(255)"/>
            <column name="request_hash" type="varchar(255)"/>
            <column name="status" type="varchar(255)"/>
            <column name="response_json" type="jsonb"/>
            <column name="response_status" type="integer"/>
            <column name="error_code" type="varchar(100)"/>
            <column name="error_message" type="varchar(500)"/>
            <column name="owner_keycloak_user_id" type="${uuidType}">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="00000004-2" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_transfer_command_transfer"/>
            </not>
        </preConditions>

        <addForeignKeyConstraint
                baseTableName="transfer_commands"
                baseColumnNames="transfer_id"
                referencedTableName="transfers"
                referencedColumnNames="id"
                constraintName="fk_transfer_command_transfer"/>
    </changeSet>

    <changeSet id="00000004-3" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_transfer_command_transfer_id" tableName="transfer_commands"/>
            </not>
        </preConditions>

        <createIndex indexName="idx_transfer_command_transfer_id" tableName="transfer_commands">
            <column name="transfer_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="00000004-4" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_transfer_command_status" tableName="transfer_commands"/>
            </not>
        </preConditions>

        <createIndex indexName="idx_transfer_command_status" tableName="transfer_commands">
            <column name="status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
