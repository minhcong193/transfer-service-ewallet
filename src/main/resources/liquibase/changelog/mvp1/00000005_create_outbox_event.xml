<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="00000005-1" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="outbox_events"/>
            </not>
        </preConditions>

        <createTable tableName="outbox_events">
            <!-- BaseEntity fields -->
            <column name="id" type="${uuidType}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="${dateTimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="${dateTimeType}">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="bigint"/>

            <!-- OutboxEvent specific fields -->
            <column name="event_id" type="${uuidType}">
                <constraints nullable="false"/>
            </column>
            <column name="aggregate_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="aggregate_id" type="${uuidType}">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="correlation_id" type="${uuidType}"/>
            <column name="status" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
            <column name="retry_count" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="next_retry_at" type="${dateTimeType}"/>
            <column name="processing_started_at" type="${dateTimeType}"/>
            <column name="published_at" type="${dateTimeType}"/>
            <column name="last_error" type="varchar(1000)"/>
        </createTable>
    </changeSet>

    <changeSet id="00000005-2" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="uk_outbox_events_event_id" tableName="outbox_events"/>
            </not>
        </preConditions>
        <addUniqueConstraint
                tableName="outbox_events"
                columnNames="event_id"
                constraintName="uk_outbox_events_event_id"/>
    </changeSet>

    <changeSet id="00000005-3" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_outbox_events_status_next_retry" tableName="outbox_events"/>
            </not>
        </preConditions>
        <createIndex indexName="idx_outbox_events_status_next_retry" tableName="outbox_events">
            <column name="status"/>
            <column name="next_retry_at"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="00000005-4" author="minhtc">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_outbox_events_aggregate" tableName="outbox_events"/>
            </not>
        </preConditions>
        <createIndex indexName="idx_outbox_events_aggregate" tableName="outbox_events">
            <column name="aggregate_type"/>
            <column name="aggregate_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
